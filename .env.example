# GitHub Fine-Grained Personal Access Token
# Required permissions on this repo:
#   - Contents: Read and write
#   - Pull requests: Read and write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username or organization name
GITHUB_OWNER=your-username

# The repository name (must match the repo this code lives in)
GITHUB_REPO=republican-business-map

# Default branch to merge PRs into (usually "main")
GITHUB_BRANCH=main
